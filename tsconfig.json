{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@surdeddd/wmkit": ["./src/index.ts"],
      "@surdeddd/wmkit/react": ["./src/adapters/react.ts"],
      "@surdeddd/wmkit/vue": ["./src/adapters/vue.ts"],
      "@surdeddd/wmkit/svelte": ["./src/adapters/svelte.ts"],
      "@surdeddd/wmkit/solid": ["./src/adapters/solid.ts"],
      "@surdeddd/wmkit/persist": ["./src/plugins/persist.ts"],
      "@surdeddd/wmkit/popout": ["./src/plugins/popout.ts"]
    }
  },
  "include": [
    "src",
    "tests",
    "site/src",
    "site/test",
    "site/vite.config.ts",
    "tsup.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "site/dist"]
}
